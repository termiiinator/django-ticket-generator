# ── Required ────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# ── Application ─────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
# Leave unset to use SQLite (development only).
# Uncomment and configure for PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/exam_tickets

# ── Security (applied automatically when DEBUG=False) ────────────────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── Email (optional) ─────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
